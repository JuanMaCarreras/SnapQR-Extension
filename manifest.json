{
  "manifest_version": 3,
  "name": "SnapQR",
  "version": "1.0",
  "permissions": ["activeTab", "tabs", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": "icon128.png"
  },
  "web_accessible_resources": [{
    "resources": ["jsQR.js"],
    "matches": ["<all_urls>"]
  }]
}